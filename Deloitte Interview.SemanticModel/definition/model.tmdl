model Model
	culture: en-IN
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["financials","WeatherDetails"]

ref table financials
ref table WeatherDetails

ref role 'Country Role'

ref cultureInfo en-IN

