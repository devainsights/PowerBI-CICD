table 'Measure Table'
	lineageTag: 6227aa81-8072-458a-a741-4ec27eb1a841

	measure 'Quanity Sold' = SUM('Sales Data'[OrderQuantity])
		formatString: #,0
		lineageTag: cf327837-00ec-4f07-82c0-90efaedc2f11

	measure 'Quantity Returned' = SUM('Returns Data'[ReturnQuantity])
		formatString: 0
		lineageTag: a96ecaf7-a9b7-491d-adc4-a812463228f5

	measure 'Average Retail Price' = AVERAGE('Product Lookup'[ProductPrice])
		formatString: "₹"\ #,0.###############;#,0.###############\ -"₹";"₹"\ #,0.###############
		lineageTag: e57270e4-7356-4013-9d14-41bc90ecb29c

		annotation PBI_FormatHint = {"currencyCulture":"en-IN"}

	measure 'Total Returns' = COUNT('Returns Data'[ReturnQuantity])
		formatString: #,0
		lineageTag: 362a905d-3826-4cbe-84d2-2e28dd921e37

	measure 'Total Orders' = DISTINCTCOUNT('Sales Data'[OrderNumber])
		formatString: #,0
		lineageTag: fdf3a905-8258-4c58-97af-42a8b7b78b6a

	measure 'Total Customers' =
			
			DISTINCTCOUNT(
			    'Sales Data'[CustomerKey])
		formatString: 0
		lineageTag: f2259240-383a-4bb5-9ed3-cf2654f8feae

	measure 'Return Rate' =
			
			DIVIDE([Quantity Returned],[Quanity Sold],"No Sales")
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 46cdfc18-20c5-4a08-b3b5-308376b1bbfc

	measure 'Bulk Orders' =
			
			CALCULATE(
			    [Total Orders],
			    'Sales Data'[OrderQuantity] > 1
			)
		formatString: 0
		lineageTag: 467d1343-6497-48fc-adff-66c2e5c4f3e1

	measure 'Weekend orders' =
			
			CALCULATE(
			    [Total Orders],
			    'Calendar Lookup'[Weekend] = "Weekend"
			)
		formatString: 0
		lineageTag: 10339c94-d819-40f7-88e9-8a574e746f76

	measure 'Bike Returns' =
			
			CALCULATE(
			    [Total Returns],
			    'Product Categories Lookup'[CategoryName] = "Bikes"
			)
		formatString: 0
		lineageTag: 6d69e9a0-a9bf-469f-967e-43aec881568e

	measure 'Bike Sales' =
			
			CALCULATE(
			    [Quanity Sold],
			    'Product Categories Lookup'[CategoryName] = "Bikes"
			)
		formatString: 0
		lineageTag: 4b29394c-6f50-4a11-98ae-346ea0b7be81

	measure 'Bike Return Rate' =
			
			CALCULATE(
			    [Return Rate],
			    'Product Categories Lookup'[CategoryName] = "Bikes"
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 621aa375-4f5a-41b3-94bf-c52d7ed6818a

	measure 'All Orders' = ```
			
			CALCULATE( 
			    [Total Orders],
			    ALL('Sales Data')
			)
			```
		formatString: 0
		lineageTag: 8f94578f-b5c1-4d7e-9e23-deeb564506ac

	measure '% of All Orders' =
			
			DIVIDE(
			    [Total Orders],
			    [All Orders]
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: ab528e4f-b3c5-4bf5-bb2f-e775387533c9

	measure 'Overall Average Price' =
			
			CALCULATE(
			    [Average Retail Price],
			    ALL(
			        'Product Lookup'
			    )
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 8a3956f2-f3f2-4505-bf1f-8822ebea1588

	measure 'All Returns' =
			
			CALCULATE(
			    [Total Returns],
			    ALL(
			        'Returns Data'
			    )
			)
		formatString: 0
		lineageTag: 54c3323a-0358-4ab6-8cb0-ebc413ca95b8

	measure '% of All Returns' =
			
			DIVIDE(
			    [Total Returns],
			    [All Returns]
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 62244c23-8f1c-4727-b046-6ac491995c67

	measure 'High ticket order' =
			
			CALCULATE(
			    [Total Orders],
			    FILTER(
			        'Product Lookup',
			        'Product Lookup'[ProductPrice] > [Overall Average Price]
			    )
			)
		formatString: 0
		lineageTag: 6438974b-38a7-4090-9102-839d34670125

	measure 'Total Revenue' = ```
			
			SUMX(
			    'Sales Data',
			    'Sales Data'[OrderQuantity] * 
			    RELATED(
			        'Product Lookup'[ProductPrice]
			    )
			)
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 3ac712e4-a702-4627-a8ef-93139c089eea

	measure 'YTD Revenue' =
			
			CALCULATE(
			    [Total Revenue],
			    DATESYTD(
			        'Calendar Lookup'[Date]
			    )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 624b609a-bae1-464d-a887-38e394e2e2e4

	measure 'Previous Month Revenue' = ```
			
			CALCULATE(
			    [Total Revenue],
			    DATEADD(
			        'Calendar Lookup'[Date],
			        -1,
			        MONTH
			    )
			)
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 9df69403-2957-465c-a76c-1247839f2e84

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Revenue Target' =
			
			[Previous Month Revenue] * 1.1
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: a41e03d3-d1fc-4dc5-bb25-56563245aeff

	measure '10-day Rolling Revenue' =
			
			CALCULATE(
			    [Total Revenue],
			    DATESINPERIOD(
			        'Calendar Lookup'[Date],
			        MAX(
			            'Calendar Lookup'[Date]
			        ),
			        -10,
			        DAY
			    )
			)
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: d613d3aa-99be-4b6f-b0a1-b763a3840ccb

	measure 'Total Cost' =
			
			SUMX(
			    'Sales Data',
			    'Sales Data'[OrderQuantity]
			    *
			    RELATED(
			        'Product Lookup'[ProductCost]
			    )
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 1b443c60-b7ff-458e-ae59-9946c7d356fc

	measure 'Total Profit' =
			
			[Total Revenue] - [Total Cost]
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: d9d42ef1-0895-450f-b0b3-fe72ee3decf5

	measure 'Previous Month Profit' =
			
			CALCULATE(
			    [Total Profit],
			    DATEADD(
			        'Calendar Lookup'[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: "₹"\ #,0.###############;#,0.###############\ -"₹";"₹"\ #,0.###############
		lineageTag: 8c77e283-ffc4-4136-9ad3-84e8a049222f

		annotation PBI_FormatHint = {"currencyCulture":"en-IN"}

	measure 'Previous Month Returns' =
			
			CALCULATE(
			    [Total Returns],
			    DATEADD(
