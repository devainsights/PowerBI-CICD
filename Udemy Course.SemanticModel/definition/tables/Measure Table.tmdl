			        -1,
			        MONTH
			    )
			)
		formatString: 0
		lineageTag: a224289c-3fbe-48d0-8d27-98135f4816c0

	measure 'Previous Month Orders' =
			
			CALCULATE(
			    [Total Orders],
			    DATEADD(
			        'Calendar Lookup'[Date],
			        -1,
			        MONTH
			    )
			)
		formatString: 0
		lineageTag: 86ac08be-03df-4e92-9486-6f22e8b810e6

	measure 'Revenue Target Gap' =
			
			[Total Revenue] - [Revenue Target]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: f65b2d33-f1f0-4e79-8c22-d75c31a8ed26

	measure 'Profit Target' =
			
			[Previous Month Profit] * 1.1
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 84b331f3-4add-4e0b-956d-dd262bf543c9

	measure 'Profit Target Gap' =
			
			[Total Profit] - [Profit Target]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 3b219b41-4e96-46f7-aeb7-6386464b730f

	measure 'Order Target' =
			
			[Previous Month Orders] *1.1
		formatString: 0
		lineageTag: f5dcd1d6-17f2-4040-97d8-8ca37197308a

	measure 'Order Target Gap' =
			
			[Total Orders] - [Order Target]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: c8cf8741-0730-4205-bd6a-a080044ef82b

	measure 'Average Revenue Per Customer' =
			
			DIVIDE(
			    [Total Revenue],
			    [Total Customers]
			)
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: f0232de2-7f67-4fd3-80ca-6c556a0dccab

	measure '90-day Rolling Profit' =
			
			CALCULATE(
			    [Total Profit],
			    DATESINPERIOD(
			        'Calendar Lookup'[Date],
			        LASTDATE(
			            'Calendar Lookup'[Date]
			        ),
			        -90,
			        DAY
			    )
			)
		formatString: "₹"\ #,0;#,0\ -"₹";"₹"\ #,0
		lineageTag: e0b66c60-85cf-4a4d-8b45-064af7b99981

		annotation PBI_FormatHint = {"currencyCulture":"en-IN"}

	measure 'Total Orders (CUstomer details)' =
			
