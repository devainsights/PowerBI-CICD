table 'Customer Lookup'
	excludeFromModelRefresh
	lineageTag: 630f1706-7ac3-4cf0-8d6b-c0447ea61ad4

	measure 'Full Name (Customer details)' =
			
			IF(
			    HASONEVALUE(
			        'Customer Lookup'[CustomerKey]
			    ),
			    MAX(
			        'Customer Lookup'[Full Name]
			    ),
			    "Multiple Names"
			)
		lineageTag: 02d1943a-bfde-4e13-a62c-6bc2012aa800

	column CustomerKey
		dataType: int64
		isKey
		formatString: 0
		lineageTag: 4d78f8ed-ed51-43e8-9738-7a224286ed10
