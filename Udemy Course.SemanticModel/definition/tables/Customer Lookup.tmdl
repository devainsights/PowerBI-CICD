	column 'Full Name'
		dataType: string
		lineageTag: 10b62dd0-e8b4-4c0a-8bb7-a9f21bb1d2eb
		summarizeBy: none
		sourceColumn: Full Name

		annotation SummarizationSetBy = Automatic

	column 'Domain Name'
		dataType: string
		lineageTag: 81ab0120-5769-4b74-995c-99d5150b35ae
		summarizeBy: none
		sourceColumn: Domain Name

		annotation SummarizationSetBy = Automatic

	column 'Is Parent ?' = IF('Customer Lookup'[TotalChildren] >0, "Yes","No")
		lineageTag: ca767118-34ea-4ce6-a89b-51b08046892b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Customer Priority' =
			
			IF('Customer Lookup'[Is Parent ?] = "Yes" && 'Customer Lookup'[AnnualIncome] > 100000,
			"Priority",
			"Standard"
			)
		lineageTag: accfa7c4-ca50-4a4e-aa04-3f74d07b64fc
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Income Level' =
			
			SWITCH(
			    TRUE(),
			    'Customer Lookup'[AnnualIncome] >= 150000,"Very High",
			    'Customer Lookup'[AnnualIncome] >= 100000,"High",
			    'Customer Lookup'[AnnualIncome] >= 50000,"Average",
			    "Low"
			)
		lineageTag: 6aa311ee-1698-4d9c-99a1-639e690e7f08
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Education Category' =
			
			SWITCH(
			    'Customer Lookup'[EducationLevel],
			     "High school", "High School",
			     "Partial High School", "High School",
			    "Bachelors", "Undergrad",
			    "Partial College", "Undergrad",
			    "Graduate Degree","Graduate"
			)
		lineageTag: 1fd7c224-de19-4d6a-935d-fc20c1f5995a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Customer Full Name (CC)' =
			
			'Customer Lookup'[Prefix] & " " & 'Customer Lookup'[FirstName] & " " & 'Customer Lookup'[LastName]
		lineageTag: d4e789c2-2cbe-42aa-b31a-360c61953999
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Birth Year' =
			
			YEAR('Customer Lookup'[BirthDate])
		formatString: 0
		lineageTag: 338fcc60-fccf-4891-9adf-a87288214a24
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

