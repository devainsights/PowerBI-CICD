table 'Sales Table'
	lineageTag: 16efcbd2-6a09-4a63-a47a-a8b6ed508b1b

	refreshPolicy
		policyType: basic
		rollingWindowGranularity: year
		rollingWindowPeriods: 5
		incrementalGranularity: day
		incrementalPeriods: 2
		pollingExpression = let #"MaxDate/Time" = List.Max(#"Sales Table"[#"Date/Time"]), accountForNull = if #"MaxDate/Time" = null then #datetime(1901, 01, 01, 00, 00, 00) else #"MaxDate/Time" in accountForNull
		sourceExpression =
			let
			    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Date = _t, Sales = _t, Quantity = _t, #"Gross Profit" = _t]),
			    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Date", type date}, {"Sales", type number}, {"Quantity", Int64.Type}, {"Gross Profit", type number}}),
			    #"Inserted Date/Time" = Table.AddColumn(#"Changed Type", "Date/Time", each DateTime.From([Date]), type datetime),
			    #"Filtered Rows" = Table.SelectRows(#"Inserted Date/Time", each [#"Date/Time"] >= RangeStart and [#"Date/Time"] < RangeEnd)
			in
			    #"Filtered Rows"

