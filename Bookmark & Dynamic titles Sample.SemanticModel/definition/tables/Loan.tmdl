table Loan
	lineageTag: f14f4629-aa25-4891-8e13-8a0a0b40e6da

	measure 'Loan Amount' = DIVIDE(SUM(Loan[Loan]),EMISimulator[EMISimulator Value])
		formatString: #,0
		lineageTag: cd8216c8-f243-4273-8607-103b538eb630

	measure '% loan amount' = sum(Loan[Loan]) * EMISimulator[EMISimulator Value] /100
		formatString: #,0
		lineageTag: 6210f692-dd05-42ce-858c-e4e9e94597cb

	column Employee
		dataType: string
		lineageTag: a73b20f9-5fc1-43dc-8e1c-cd1b0732988c
