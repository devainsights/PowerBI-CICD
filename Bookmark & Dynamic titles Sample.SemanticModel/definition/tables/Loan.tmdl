				    Loan_Sheet = Source{[Item="Loan",Kind="Sheet"]}[Data],
				    #"Promoted Headers" = Table.PromoteHeaders(Loan_Sheet, [PromoteAllScalars=true]),
				    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{" Employee ", type text}, {" Location  ", type text}, {" Loan   ", Int64.Type}}),
				    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{" Loan   ", "Loan"}, {" Employee ", "Employee"}, {" Location  ", "Location"}})
				in
				    #"Renamed Columns"

